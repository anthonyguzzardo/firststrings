{
  "name": "first-strings",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:psql": "docker exec -it first_strings_pg psql -U first_strings -d first_strings",
    "bootstrap": "tsx --env-file=.env src/scripts/bootstrap-curated-roster.ts",
    "ingest:atp": "tsx --env-file=.env src/scripts/ingest-sackmann-atp.ts",
    "ingest:wta": "tsx --env-file=.env src/scripts/ingest-sackmann-wta.ts",
    "ingest:mcp": "tsx --env-file=.env src/scripts/ingest-sackmann-mcp.ts",
    "ingest:rankings": "tsx --env-file=.env src/scripts/ingest-sackmann-rankings.ts",
    "ingest:venues": "tsx --env-file=.env src/scripts/ingest-wikidata-venues.ts",
    "refresh:elo": "tsx --env-file=.env src/scripts/refresh-elo.ts",
    "refresh:career-stats": "tsx --env-file=.env src/scripts/refresh-career-stats.ts",
    "refresh:clutch": "tsx --env-file=.env src/scripts/refresh-clutch.ts",
    "refresh:leverage": "node --stack-size=16000 --max-old-space-size=4096 --import tsx --env-file=.env src/scripts/refresh-leverage.ts",
    "refresh:serve-zones": "tsx --env-file=.env src/scripts/refresh-serve-zones.ts",
    "refresh:ai-cards": "tsx --env-file=.env src/scripts/refresh-ai-cards.ts",
    "refresh:compare-cards": "tsx --env-file=.env src/scripts/refresh-compare-cards.ts",
    "refresh:match-canonical": "tsx --env-file=.env src/scripts/refresh-match-canonical.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@astrojs/node": "^9.0.0",
    "astro": "^5.0.0",
    "postgres": "^3.4.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "csv-parse": "^6.2.1",
    "tsx": "^4.21.0"
  }
}
