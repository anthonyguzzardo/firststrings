# Local Postgres connection (matches docker-compose.yml defaults)
FIRSTSTRINGS_PG_URL=postgres://first_strings:first_strings_dev@127.0.0.1:5433/first_strings

# Optional overrides if you change the compose defaults
# POSTGRES_USER=first_strings
# POSTGRES_PASSWORD=first_strings_dev
# POSTGRES_DB=first_strings

# Anthropic key — used for player narratives and the Ask the Oracle widget
ANTHROPIC_API_KEY=sk-ant-...
