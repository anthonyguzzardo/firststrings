---
interface Props {
  label: string;
  value: string | number | null | undefined;
  suffix?: string;
  small?: boolean;
}

const { label, value, suffix, small = false } = Astro.props;
const display = value === null || value === undefined || value === '' ? '—' : value;
---
<div class="fs-stat">
  <span class="fs-stat__label">{label}</span>
  <span class={`fs-stat__value${small ? ' fs-stat__value--small' : ''}`}>
    {display}{suffix && display !== '—' ? <span class="fs-stat__suffix">{suffix}</span> : null}
  </span>
</div>
