---
import type { CareerLedger, MatchRecord } from '../lib/libPlayers';
import type { PlayerCareerStats, PlayerSurfaceStats } from '../lib/libDb';
import { formatPrizeMoneyUsd, winPct, formatMilesTraveled } from '../lib/libPlayers';

interface Props {
  ledger: CareerLedger;
  status: 'active' | 'retired';
  liveStats?: PlayerCareerStats | null;
}

const { ledger, status, liveStats } = Astro.props;
const { prizeMoneyUsd, matchRecord, surfaceSplits, asOfIso, source, estimatedMilesTraveled, milesTraveledNote } = ledger;
const hasPrize = prizeMoneyUsd !== null && prizeMoneyUsd !== undefined;
const hasMiles = typeof estimatedMilesTraveled === 'number' && estimatedMilesTraveled > 0;

// SQL career-stats override curated when present. Source line below picks up
// the difference and credits Sackmann.
const liveToRecord = (s: PlayerSurfaceStats): MatchRecord => ({ wins: s.matchesWon, losses: s.matchesLost });
const liveOverall = liveStats?.overall;
const effectiveRecord: MatchRecord | undefined = liveOverall
  ? liveToRecord(liveOverall)
  : (matchRecord ?? undefined);
const hasRecord = effectiveRecord !== undefined;

const surfaces: Array<{ key: 'hard' | 'clay' | 'grass' | 'carpet'; label: string; record?: MatchRecord }> = liveStats
  ? [
      { key: 'hard',   label: 'Hard',   record: liveStats.hard   ? liveToRecord(liveStats.hard)   : undefined },
      { key: 'clay',   label: 'Clay',   record: liveStats.clay   ? liveToRecord(liveStats.clay)   : undefined },
      { key: 'grass',  label: 'Grass',  record: liveStats.grass  ? liveToRecord(liveStats.grass)  : undefined },
      { key: 'carpet', label: 'Carpet', record: liveStats.carpet ? liveToRecord(liveStats.carpet) : undefined },
    ].filter((s) => s.record !== undefined)
  : [
      { key: 'hard',   label: 'Hard',   record: surfaceSplits?.hard   },
      { key: 'clay',   label: 'Clay',   record: surfaceSplits?.clay   },
      { key: 'grass',  label: 'Grass',  record: surfaceSplits?.grass  },
      { key: 'carpet', label: 'Carpet', record: surfaceSplits?.carpet },
    ].filter((s) => s.record !== undefined);

const asOfFormatted = asOfIso
  ? new Date(asOfIso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : null;
---
<section class="fs-section fs-ledger">
  <div class="fs-section__title">
    <h2>Career Ledger</h2>
    <span class="fs-eyebrow">{status === 'active' ? 'In progress' : 'Final ledger'}</span>
  </div>

  <div class="fs-ledger__top">
    {hasPrize && (
      <div class="fs-ledger__hero">
        <div class="fs-ledger__hero-value">{formatPrizeMoneyUsd(prizeMoneyUsd!)}</div>
        <div class="fs-ledger__hero-label">Career prize money (USD)</div>
      </div>
    )}

    {hasRecord && (
      <div class="fs-ledger__record">
        <div class="fs-ledger__record-label">Career record (singles)</div>
        <div class="fs-ledger__record-value">
          <span class="fs-ledger__wins">{effectiveRecord!.wins.toLocaleString('en-US')}</span>
          <span class="fs-ledger__sep">–</span>
          <span class="fs-ledger__losses">{effectiveRecord!.losses.toLocaleString('en-US')}</span>
          {winPct(effectiveRecord!) && <span class="fs-ledger__pct">{winPct(effectiveRecord!)}</span>}
        </div>
      </div>
    )}
  </div>

  {surfaces.length > 0 && (
    <div class="fs-ledger__surfaces">
      <div class="fs-eyebrow" style="margin-bottom: 0.75rem;">By surface</div>
      <div class="fs-ledger__surfaces-grid">
        {surfaces.map((s) => (
          <div class={`fs-ledger__surface fs-ledger__surface--${s.key}`}>
            <div class="fs-ledger__surface-label">{s.label}</div>
            <div class="fs-ledger__surface-record">
              <span>{s.record!.wins}</span>
              <span class="fs-ledger__sep">–</span>
              <span>{s.record!.losses}</span>
            </div>
            {winPct(s.record) && <div class="fs-ledger__surface-pct">{winPct(s.record)}</div>}
          </div>
        ))}
      </div>
    </div>
  )}

  {hasMiles && (
    <div class="fs-ledger__miles">
      <div class="fs-ledger__miles-head">
        <span class="fs-eyebrow">Estimated miles traveled (round trips to title cities)</span>
      </div>
      <div class="fs-ledger__miles-value">{formatMilesTraveled(estimatedMilesTraveled!)}</div>
      {milesTraveledNote && <p class="fs-ledger__miles-note">{milesTraveledNote}</p>}
    </div>
  )}

  {(asOfFormatted || source || liveStats) && (
    <p class="fs-ledger__footer">
      {liveStats && <span>Match record + surface splits from Sackmann tour-level singles · </span>}
      {asOfFormatted && <span>Curated as of {asOfFormatted}</span>}
      {asOfFormatted && source && <span> · </span>}
      {source && <span>{Array.isArray(source) ? `${source.length} sources` : source}</span>}
    </p>
  )}
</section>
