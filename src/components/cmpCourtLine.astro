---
// Single-stroke court-line divider — DESIGN.md §Surface Motifs.
// "An exclamation, not a divider — use sparingly." Reserve for editorial
// transitions (hero → bio, last point → recap, etc.), not as a generic rule.
//
// The draw-in is scroll-driven via animation-timeline: view(), gated on
// prefers-reduced-motion. Browsers without view-timeline support render the
// line fully drawn — no JS, no fallback gymnastics needed.

interface Props {
  tone?: 'neutral' | 'rg' | 'wim' | 'ao' | 'uso';
  animate?: boolean;
}

const { tone = 'neutral', animate = true } = Astro.props;
const colorVar =
  tone === 'rg'  ? 'var(--slam-rg)'  :
  tone === 'wim' ? 'var(--slam-wim)' :
  tone === 'ao'  ? 'var(--slam-ao)'  :
  tone === 'uso' ? 'var(--slam-uso)' :
                   'var(--court-line-mute)';
---
<svg
  viewBox="0 0 1100 4"
  preserveAspectRatio="none"
  class:list={['fs-courtline', animate && 'fs-courtline--anim']}
  style={`color: ${colorVar}`}
  aria-hidden="true"
>
  <line
    x1="0" y1="2" x2="1100" y2="2"
    stroke="currentColor" stroke-width="1"
    vector-effect="non-scaling-stroke"
    pathLength="100"
  />
</svg>

<style>
  .fs-courtline {
    display: block;
    width: 100%;
    height: 4px;
    margin: 2.25rem 0;
  }
  .fs-courtline line {
    stroke-dasharray: 100;
    stroke-dashoffset: 0;
  }
  @keyframes fs-courtline-draw {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .fs-courtline--anim line {
        stroke-dashoffset: 100;
        animation: fs-courtline-draw var(--ease-court) both;
        animation-timeline: view();
        animation-range: entry 20% cover 60%;
      }
    }
  }
</style>
