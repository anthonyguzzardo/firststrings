---
import type { Quote } from '../lib/libPlayers';
import { quoteText, quoteAttr } from '../lib/libPlayers';

interface Props {
  quotes: Quote[];
}

const { quotes } = Astro.props;
---
{quotes.length > 0 && (
  <section class="fs-section fs-quotes">
    <div class="fs-section__title">
      <h2>In Their Own Words</h2>
      <span class="fs-eyebrow">{quotes.length} quote{quotes.length === 1 ? '' : 's'}</span>
    </div>
    <ul class="fs-quote-list">
      {quotes.map((q) => {
        const text = quoteText(q);
        const { source, year, context } = quoteAttr(q);
        return (
          <li class="fs-quote">
            <blockquote class="fs-quote__text">{text}</blockquote>
            <footer class="fs-quote__attr">
              {context && <span class="fs-quote__context">{context}</span>}
              {source && <cite class="fs-quote__source">— {source}{year ? `, ${year}` : ''}</cite>}
              {!source && year && <cite class="fs-quote__source">— {year}</cite>}
            </footer>
          </li>
        );
      })}
    </ul>
  </section>
)}
