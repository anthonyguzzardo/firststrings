---
import { getAllPlayers, getPlayerImagePath } from '../lib/libPlayers';

// Ship a minimal client-side index — name, slug, tour, country code, photo.
// Roster is small so we don't need Fuse; a substring + initials matcher
// inline is plenty.
interface Entry {
  slug: string;
  name: string;
  haystack: string;
  initials: string;
  tour: string;
  country: string;
  photo: string;
}

const all = getAllPlayers();
const entries: Entry[] = all.map((p) => {
  const country = p.birthplace.split(',').slice(-1)[0]?.trim() ?? '';
  const initials = p.fullName.split(/\s+/).map((w) => w[0] ?? '').join('').toLowerCase();
  return {
    slug: p.slug,
    name: p.fullName,
    haystack: `${p.fullName} ${country} ${p.tour}`.toLowerCase(),
    initials,
    tour: p.tour,
    country,
    photo: getPlayerImagePath(p),
  };
});
---
<div id="fs-quick" class="fs-quick" hidden>
  <div class="fs-quick__backdrop" data-quick-close></div>
  <div class="fs-quick__panel" role="dialog" aria-label="Quick search">
    <div class="fs-quick__head">
      <span class="fs-eyebrow">Quick search</span>
      <kbd class="fs-quick__hint">esc</kbd>
    </div>
    <input
      type="search"
      class="fs-quick__input"
      placeholder="Search players · type a name, country, or initials"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
      aria-label="Search the roster"
    />
    <ul class="fs-quick__results" role="listbox" aria-label="Search results"></ul>
    <div class="fs-quick__foot">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script is:inline define:vars={{ entries }}>
  // Tiny scorer: name-prefix > full substring > initials match > haystack
  // substring. Returns null on no match. Higher score = better.
  function score(q, e) {
    if (!q) return 1; // empty query keeps every result, in roster order
    const ql = q.toLowerCase().trim();
    if (!ql) return 1;
    const name = e.name.toLowerCase();
    if (name.startsWith(ql)) return 100 - name.length;
    // first-name / last-name prefix
    for (const part of name.split(/\s+/)) {
      if (part.startsWith(ql)) return 80;
    }
    if (e.initials === ql) return 70;
    if (e.initials.startsWith(ql)) return 65;
    if (name.includes(ql)) return 50;
    if (e.haystack.includes(ql)) return 30;
    return null;
  }

  const overlay  = document.getElementById('fs-quick');
  if (!overlay) return;
  const input    = overlay.querySelector('.fs-quick__input');
  const list     = overlay.querySelector('.fs-quick__results');
  let active     = 0;
  let current    = entries.slice();

  function render() {
    list.innerHTML = '';
    current.forEach((e, i) => {
      const li = document.createElement('li');
      li.className = 'fs-quick__row' + (i === active ? ' is-active' : '');
      li.setAttribute('role', 'option');
      li.dataset.slug = e.slug;
      li.innerHTML = `
        <a href="/players/${e.slug}" class="fs-quick__row-link">
          <img src="${e.photo}" alt="" class="fs-quick__row-photo" loading="lazy" />
          <span class="fs-quick__row-name">${e.name}</span>
          <span class="fs-quick__row-meta">${e.country} · ${e.tour}</span>
        </a>`;
      list.appendChild(li);
    });
  }

  function update(q) {
    const ranked = entries
      .map((e) => ({ e, s: score(q, e) }))
      .filter((x) => x.s !== null)
      .sort((x, y) => y.s - x.s)
      .slice(0, 12)
      .map((x) => x.e);
    current = ranked;
    active = 0;
    render();
  }

  function open() {
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    input.value = '';
    update('');
    setTimeout(() => input.focus(), 0);
  }
  function close() {
    overlay.hidden = true;
    document.body.style.overflow = '';
  }
  function navigate(d) {
    if (current.length === 0) return;
    active = (active + d + current.length) % current.length;
    render();
  }
  function commit() {
    const e = current[active];
    if (e) window.location.href = `/players/${e.slug}`;
  }

  // Global shortcuts: Cmd/Ctrl+K and "/"
  document.addEventListener('keydown', (ev) => {
    if (overlay.hidden) {
      const isCmdK = (ev.key === 'k' || ev.key === 'K') && (ev.metaKey || ev.ctrlKey);
      const isSlash = ev.key === '/' && document.activeElement?.tagName !== 'INPUT'
                                       && document.activeElement?.tagName !== 'TEXTAREA';
      if (isCmdK || isSlash) { ev.preventDefault(); open(); }
      return;
    }
    if (ev.key === 'Escape') { ev.preventDefault(); close(); }
    else if (ev.key === 'ArrowDown') { ev.preventDefault(); navigate(1); }
    else if (ev.key === 'ArrowUp')   { ev.preventDefault(); navigate(-1); }
    else if (ev.key === 'Enter')     { ev.preventDefault(); commit(); }
  });

  input.addEventListener('input', (ev) => update(ev.target.value));
  overlay.addEventListener('click', (ev) => {
    if (ev.target.matches('[data-quick-close]')) close();
  });
  list.addEventListener('mouseover', (ev) => {
    const row = ev.target.closest('.fs-quick__row');
    if (!row) return;
    const idx = Array.from(list.children).indexOf(row);
    if (idx >= 0 && idx !== active) { active = idx; render(); }
  });
</script>

<style>
  .fs-quick { position: fixed; inset: 0; z-index: 100; }
  .fs-quick[hidden] { display: none; }

  .fs-quick__backdrop {
    position: absolute; inset: 0;
    background: rgba(20, 17, 12, 0.55);
    backdrop-filter: blur(2px);
  }

  .fs-quick__panel {
    position: relative;
    width: min(640px, calc(100% - 2rem));
    margin: 12vh auto 0;
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: 6px;
    box-shadow: 0 24px 60px -20px rgba(0,0,0,0.35);
    padding: 1rem 1.25rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .fs-quick__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .fs-quick__input {
    width: 100%;
    border: 0;
    border-bottom: 1px solid var(--rule);
    background: transparent;
    font: 500 1.4rem/1.4 var(--serif);
    color: var(--ink);
    padding: 0.4rem 0;
    outline: none;
  }
  .fs-quick__input:focus { border-bottom-color: var(--slam-rg); }

  .fs-quick__results {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0;
    max-height: 50vh;
    overflow-y: auto;
  }

  .fs-quick__row { padding: 0; border-radius: 3px; }
  .fs-quick__row.is-active { background: var(--bg-elevated); }
  .fs-quick__row-link {
    display: grid;
    grid-template-columns: 32px 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.4rem 0.5rem;
    color: var(--ink);
    text-decoration: none;
  }
  .fs-quick__row-photo {
    width: 32px; height: 32px;
    border-radius: 3px;
    object-fit: cover;
    background: var(--bg-elevated);
    border: 1px solid var(--rule);
  }
  .fs-quick__row-name {
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1;
  }
  .fs-quick__row-meta {
    font-size: 0.75rem;
    color: var(--ink-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .fs-quick__row.is-active .fs-quick__row-link { color: var(--slam-rg); }

  .fs-quick__foot {
    display: flex;
    gap: 1rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--rule);
    font-size: 0.72rem;
    color: var(--ink-soft);
  }
  .fs-quick__foot kbd, .fs-quick__hint {
    display: inline-block;
    padding: 0.05rem 0.35rem;
    border: 1px solid var(--rule);
    border-radius: 2px;
    background: var(--bg-elevated);
    font-family: var(--mono);
    font-size: 0.7rem;
    margin: 0 0.2rem 0 0;
    color: var(--ink-muted);
  }
</style>
