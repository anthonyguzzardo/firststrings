---
import type { Player } from '../lib/libPlayers';
import { getPlayerImagePath } from '../lib/libPlayers';
import type { HeadToHead } from '../lib/libDb';

interface Props {
  playerA: Player;
  playerB: Player;
  h2h: HeadToHead;
}

const { playerA, playerB, h2h } = Astro.props;

const surfaces: Array<{ key: 'hard' | 'clay' | 'grass' | 'carpet'; label: string }> = [
  { key: 'hard',   label: 'Hard'   },
  { key: 'clay',   label: 'Clay'   },
  { key: 'grass',  label: 'Grass'  },
  { key: 'carpet', label: 'Carpet' },
];
const splits = surfaces
  .map((s) => ({ ...s, ...h2h.bySurface[s.key] }))
  .filter((s) => s.a + s.b > 0);

const total = h2h.aWins + h2h.bWins;
const wonByA = h2h.lastMeeting?.winnerSlug === playerA.slug;
---
<article class="fs-h2h">
  <header class="fs-h2h__header">
    <span class="fs-eyebrow fs-eyebrow--block">vs.</span>
    <a href={`/players/${playerB.slug}`} class="fs-h2h__rival-link">{playerB.fullName}</a>
    <span class="fs-h2h__count">{total} meeting{total === 1 ? '' : 's'}</span>
  </header>

  <div class="fs-h2h__grid">
    <div class="fs-h2h__player">
      <div class="fs-h2h__photo"><img src={getPlayerImagePath(playerA)} alt="" loading="lazy" /></div>
      <div class="fs-h2h__name">{playerA.fullName}</div>
    </div>
    <div class="fs-h2h__score" aria-label={`${h2h.aWins} to ${h2h.bWins}`}>
      <span class="fs-h2h__score-num">{h2h.aWins}</span>
      <span class="fs-h2h__score-sep" aria-hidden="true">—</span>
      <span class="fs-h2h__score-num">{h2h.bWins}</span>
    </div>
    <div class="fs-h2h__player">
      <div class="fs-h2h__photo"><img src={getPlayerImagePath(playerB)} alt="" loading="lazy" /></div>
      <div class="fs-h2h__name">{playerB.fullName}</div>
    </div>
  </div>

  {splits.length > 0 && (
    <ul class="fs-h2h__splits">
      {splits.map((s) => {
        const sub = s.a + s.b;
        const aPct = (s.a / sub) * 100;
        return (
          <li class={`fs-h2h__split fs-h2h__split--${s.key}`}>
            <span class="fs-h2h__split-label">{s.label}</span>
            <div class="fs-h2h__bar" style={`--a-pct: ${aPct.toFixed(1)}%`} aria-hidden="true"></div>
            <span class="fs-h2h__split-record">
              <span class="fs-h2h__split-num">{s.a}</span>
              <span class="fs-h2h__sep"> — </span>
              <span class="fs-h2h__split-num">{s.b}</span>
            </span>
          </li>
        );
      })}
    </ul>
  )}

  {h2h.lastMeeting && (
    <div class="fs-h2h__last">
      <div class="fs-h2h__last-head">
        <span class="fs-eyebrow">Last meeting</span>
        <span class="fs-h2h__last-where">
          {h2h.lastMeeting.year}
          {h2h.lastMeeting.tournament && <> · {h2h.lastMeeting.tournament}</>}
          {h2h.lastMeeting.round && <> · {h2h.lastMeeting.round}</>}
        </span>
      </div>
      {h2h.lastMeeting.winnerSlug && (
        <div class="fs-h2h__last-result">
          {wonByA
            ? `${playerA.fullName} d. ${playerB.fullName}`
            : `${playerB.fullName} d. ${playerA.fullName}`}
          {h2h.lastMeeting.score && <> · {h2h.lastMeeting.score}</>}
        </div>
      )}
    </div>
  )}
</article>

<style>
  .fs-h2h {
    display: block;
    padding: 1.5rem 0;
  }
  .fs-h2h__header {
    display: flex;
    align-items: baseline;
    gap: 0.6rem 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .fs-h2h__rival-link {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    text-wrap: balance;
    line-height: 1.05;
    flex: 1;
    min-width: 0;
  }
  .fs-h2h__rival-link:hover { color: var(--slam-rg); }
  .fs-h2h__count {
    font: 600 var(--fs-eye)/1 var(--sans);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-feature-settings: 'tnum' 1, 'lnum' 1;
    font-variant-numeric: tabular-nums lining-nums;
  }
  @media (prefers-reduced-motion: no-preference) {
    .fs-h2h__rival-link { transition: color var(--t-base) var(--ease); }
  }

  .fs-h2h__grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem 2rem;
    margin: 0.5rem 0 2rem;
  }
  .fs-h2h__player {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .fs-h2h__photo {
    width: 96px;
    height: 96px;
    border-radius: 999px;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--rule);
  }
  .fs-h2h__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .fs-h2h__name {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-wrap: balance;
    text-align: center;
    line-height: 1.1;
  }
  .fs-h2h__score {
    font-family: var(--serif);
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
    font-weight: 500;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    color: var(--ink);
    font-feature-settings: 'tnum' 1, 'lnum' 1;
    font-variant-numeric: tabular-nums lining-nums;
  }
  .fs-h2h__score-sep {
    color: var(--ink-soft);
    font-size: 0.55em;
    padding: 0 0.1em;
  }
  .fs-h2h__score-num {
    min-width: 1.1ch;
    text-align: center;
  }

  .fs-h2h__splits {
    list-style: none;
    margin: 0;
    padding: 1.25rem 0 0;
    border-top: 1px solid var(--slam-rg);
    display: grid;
    gap: 0.7rem;
  }
  .fs-h2h__split {
    display: grid;
    grid-template-columns: 5rem 1fr 5.5rem;
    align-items: center;
    gap: 1rem;
  }
  .fs-h2h__split-label {
    font: 600 var(--fs-eye)/1 var(--sans);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .fs-h2h__bar {
    height: 8px;
    border-radius: 2px;
    background: linear-gradient(
      to right,
      var(--bar-color, var(--ink)) 0%,
      var(--bar-color, var(--ink)) var(--a-pct, 50%),
      var(--bar-mute, var(--rule)) var(--a-pct, 50%),
      var(--bar-mute, var(--rule)) 100%
    );
  }
  .fs-h2h__split--hard   { --bar-color: var(--surface-hard);   --bar-mute: color-mix(in srgb, var(--surface-hard)   20%, transparent); }
  .fs-h2h__split--clay   { --bar-color: var(--surface-clay);   --bar-mute: color-mix(in srgb, var(--surface-clay)   20%, transparent); }
  .fs-h2h__split--grass  { --bar-color: var(--surface-grass);  --bar-mute: color-mix(in srgb, var(--surface-grass)  20%, transparent); }
  .fs-h2h__split--carpet { --bar-color: var(--surface-indoor); --bar-mute: color-mix(in srgb, var(--surface-indoor) 20%, transparent); }

  .fs-h2h__split-record {
    font-family: var(--serif);
    font-size: 1.05rem;
    text-align: right;
    font-feature-settings: 'tnum' 1, 'lnum' 1;
    font-variant-numeric: tabular-nums lining-nums;
  }
  .fs-h2h__sep { color: var(--ink-soft); padding: 0 0.15em; }

  .fs-h2h__last {
    margin-top: 1.75rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--rule);
  }
  .fs-h2h__last-head {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    flex-wrap: wrap;
    margin-bottom: 0.3rem;
  }
  .fs-h2h__last-where {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--ink);
    font-feature-settings: 'tnum' 1, 'lnum' 1;
    font-variant-numeric: tabular-nums lining-nums;
  }
  .fs-h2h__last-result {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--ink-muted);
    font-style: italic;
    font-feature-settings: 'tnum' 1, 'lnum' 1;
    font-variant-numeric: tabular-nums lining-nums;
  }

  @media (max-width: 600px) {
    .fs-h2h__grid {
      grid-template-columns: 1fr 1fr;
    }
    .fs-h2h__score {
      grid-column: 1 / -1;
      grid-row: 2;
      justify-content: center;
      font-size: 3.5rem;
    }
    .fs-h2h__split {
      grid-template-columns: 4rem 1fr 5rem;
      gap: 0.75rem;
    }
  }
</style>
