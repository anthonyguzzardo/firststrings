---
import LayBase from '../layouts/layBase.astro';
import CmpPlayerCard from '../components/cmpPlayerCard.astro';
import { getAllPlayers } from '../lib/libPlayers';
import '../styles/styPlayerProfile.css';

const url = new URL(Astro.request.url);
const tourFilter = url.searchParams.get('tour'); // 'ATP' | 'WTA' | null

const all = getAllPlayers();
const filtered = tourFilter ? all.filter((p) => p.tour === tourFilter) : all;

const active = filtered.filter((p) => p.status === 'active');
const legends = filtered.filter((p) => p.status === 'retired');

const tourTitle = tourFilter ? `${tourFilter} · ` : '';
---
<LayBase title={`${tourTitle}Roster`}>
  <header class="fs-roster-hero">
    <div class="fs-container">
      <div class="fs-eyebrow">First Strings</div>
      <h1>A reverence for the game.</h1>
      <p class="fs-roster-hero__tagline">
        Profiles of the legends and the next-gen — one-handers and two-handers, lefties and righties, baseline grinders and serve-and-volley artists. Built slowly, on purpose.
      </p>
    </div>
  </header>

  <section class="fs-container">
    <div class="fs-filterbar">
      <span class="fs-filterbar__label">Tour</span>
      <a href="/" class="fs-filter-btn" aria-pressed={!tourFilter}>All</a>
      <a href="/?tour=ATP" class="fs-filter-btn" aria-pressed={tourFilter === 'ATP'}>ATP</a>
      <a href="/?tour=WTA" class="fs-filter-btn" aria-pressed={tourFilter === 'WTA'}>WTA</a>
    </div>

    {active.length > 0 && (
      <section class="fs-roster-section">
        <div class="fs-roster-section__head">
          <h2>Currently Playing</h2>
          <span class="fs-roster-section__count">{active.length} player{active.length === 1 ? '' : 's'}</span>
        </div>
        <div class="fs-roster-grid">
          {active.map((p) => <CmpPlayerCard player={p} />)}
        </div>
      </section>
    )}

    {legends.length > 0 && (
      <section class="fs-roster-section">
        <div class="fs-roster-section__head">
          <h2>Legends of the Game</h2>
          <span class="fs-roster-section__count">{legends.length} player{legends.length === 1 ? '' : 's'}</span>
        </div>
        <div class="fs-roster-grid">
          {legends.map((p) => <CmpPlayerCard player={p} />)}
        </div>
      </section>
    )}

    {filtered.length === 0 && (
      <p style="padding: 4rem 0; color: var(--ink-muted); font-family: var(--serif); font-size: 1.2rem;">
        No players match this filter yet.
      </p>
    )}
  </section>
</LayBase>
