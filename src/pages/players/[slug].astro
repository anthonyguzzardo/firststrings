---
import LayBase from '../../layouts/layBase.astro';
import CmpStatTile from '../../components/cmpStatTile.astro';
import CmpShotPalette from '../../components/cmpShotPalette.astro';
import CmpTrophyCase from '../../components/cmpTrophyCase.astro';
import CmpEquipmentBag from '../../components/cmpEquipmentBag.astro';
import CmpCareerLedger from '../../components/cmpCareerLedger.astro';
import CmpAccessories from '../../components/cmpAccessories.astro';
import CmpQuotes from '../../components/cmpQuotes.astro';
import CmpProjection from '../../components/cmpProjection.astro';
import CmpEloCareerArc from '../../components/cmpEloCareerArc.astro';
import CmpCourtLine from '../../components/cmpCourtLine.astro';
import CmpHeadToHead from '../../components/cmpHeadToHead.astro';
import CmpRankingSparkline from '../../components/cmpRankingSparkline.astro';
import CmpClutch from '../../components/cmpClutch.astro';
import CmpServeRose from '../../components/cmpServeRose.astro';
import CmpShotMap from '../../components/cmpShotMap.astro';
import CmpAiInsightCard from '../../components/cmpAiInsightCard.astro';
import CmpStyleNeighbours from '../../components/cmpStyleNeighbours.astro';
import { loadAiCard } from '../../lib/libAiCards';
import { getPlayerBySlug, getAllPlayers, formatAge, formatHeight, eraLabel, getPlayerImagePath } from '../../lib/libPlayers';
import {
  getHeadToHead,
  getEloAnnualPeaksBySlug,
  getRankingAnnualBestBySlug,
  getCareerStatsBySlug,
  getPlayerClutchMetrics,
  getPlayerServeZones,
  getShotDirectionMap,
  getStyleNeighbours,
  type HeadToHead,
  type SparklinePoint,
  type PlayerCareerStats,
  type PlayerClutchMetrics,
  type ServeZones,
  type ShotDirectionMap,
  type StyleNeighbour,
} from '../../lib/libDb';
import '../../styles/styPlayerProfile.css';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const player = getPlayerBySlug(slug);
if (!player) {
  return new Response('Player not found', { status: 404 });
}

const handLabel = player.handedness === 'right' ? 'Right-handed' : 'Left-handed';
const bhLabel = player.backhandStyle === 'one-handed' ? 'One-handed backhand' : 'Two-handed backhand';

const bornDisplay = new Date(player.bornIso).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const ageOrRetired = player.status === 'active'
  ? `Age ${formatAge(player.bornIso)}`
  : player.career.retiredYear ? `Retired ${player.career.retiredYear}` : 'Retired';

// resolve rivalries
const allPlayers = getAllPlayers();
const rivalEntries = (player.rivalries ?? []).map((rivalSlug) => {
  const rival = allPlayers.find((p) => p.slug === rivalSlug);
  return { slug: rivalSlug, rival };
});

// Head-to-head against up to 3 curated rivals (DESIGN.md spec). Each call
// is independent so we Promise.all the lot. Missing DB / no-meetings entries
// drop out via filter — section disappears entirely if all three are empty.
const topRivals = rivalEntries.filter((r) => r.rival).slice(0, 3).map((r) => r.rival!);
const h2hResults = await Promise.all(
  topRivals.map(async (rival) => {
    try {
      const h2h = await getHeadToHead(player.slug, rival.slug);
      return h2h ? { rival, h2h } : null;
    } catch (e) {
      const code = (e as { code?: string } | null)?.code;
      if (code !== 'ECONNREFUSED') console.error('[H2H] DB query failed:', e);
      return null;
    }
  }),
);
const headToHeads = h2hResults.filter((x): x is { rival: typeof topRivals[number]; h2h: HeadToHead } => x !== null);

// Live career stats from tb_player_career_stats. When present, overrides the
// curated record + surface splits in the Career Ledger (the SQL number is
// canonical; curated values were approximations).
let liveStats: PlayerCareerStats | null = null;
try {
  liveStats = await getCareerStatsBySlug(player.slug);
} catch (e) {
  const code = (e as { code?: string } | null)?.code;
  if (code !== 'ECONNREFUSED') console.error('[career-stats] DB query failed:', e);
}

// Clutch metrics from MCP-charted matches. Players whose Sackmann match
// rows pre-date the Match Charting Project (or who haven't been charted
// often enough yet) get null and the section silently omits.
let clutch: PlayerClutchMetrics | null = null;
try {
  clutch = await getPlayerClutchMetrics(player.slug);
} catch (e) {
  const code = (e as { code?: string } | null)?.code;
  if (code !== 'ECONNREFUSED') console.error('[clutch] DB query failed:', e);
}

// Serve zones for the cmpServeRose. Returns null below ~200 charted serves
// so we don't render a thin sample. Same DB-down catch as the others.
let serveZones: ServeZones | null = null;
try {
  serveZones = await getPlayerServeZones(player.slug);
} catch (e) {
  const code = (e as { code?: string } | null)?.code;
  if (code !== 'ECONNREFUSED') console.error('[serve-zones] DB query failed:', e);
}

// Groundstroke direction map (FH/BH × opp FH/middle/opp BH zones).
let shotMap: ShotDirectionMap | null = null;
try {
  shotMap = await getShotDirectionMap(player.slug);
} catch (e) {
  const code = (e as { code?: string } | null)?.code;
  if (code !== 'ECONNREFUSED') console.error('[shot-map] DB query failed:', e);
}

// AI editorial paragraph from data/ai-cards/<slug>.json. Generated by
// `npm run refresh:ai-cards`; missing file → no card renders.
const aiCard = loadAiCard(player.slug);

// Style-vector kNN neighbours. Returns null when the player has no
// embedding row yet (run `npm run refresh:style-embedding`).
let styleNeighbours: StyleNeighbour[] = [];
try {
  styleNeighbours = (await getStyleNeighbours(player.slug, 5)) ?? [];
} catch (e) {
  const code = (e as { code?: string } | null)?.code;
  if (code !== 'ECONNREFUSED') console.error('[style-near] DB query failed:', e);
}

// Career-arc sparkline. Prefer official ATP/WTA rankings (lower = better);
// fall back to Elo proxy for players too historic for Sackmann's rankings
// dataset (rankings start ~1973 ATP, ~1975 WTA — and only ~1500 ranked
// players per week). DB-down catch keeps the page renderable.
let arcData: SparklinePoint[] = [];
let arcInverted = false;
try {
  const rankMap = await getRankingAnnualBestBySlug([player.slug]);
  arcData = rankMap.get(player.slug) ?? [];
  arcInverted = arcData.length > 1;
  if (!arcInverted) {
    const eloMap = await getEloAnnualPeaksBySlug([player.slug]);
    arcData = eloMap.get(player.slug) ?? [];
  }
} catch (e) {
  const code = (e as { code?: string } | null)?.code;
  if (code !== 'ECONNREFUSED') console.error('[arc] DB query failed:', e);
}

const isApprox = player.dataConfidence === 'approximate';
---
<LayBase title={player.fullName} description={player.bio.slice(0, 160)}>
  <header class="fs-hero">
    <div class="fs-container fs-hero__inner">
      <div class="fs-hero__photo-wrap" transition:name={`photo-${player.slug}`}>
        <img src={getPlayerImagePath(player)} alt={`Portrait of ${player.fullName}`} loading="eager" />
      </div>
      <div>
      <div class="fs-hero__tour">{player.tour} · {player.era.map(eraLabel).join(' / ')}</div>
      <h1 class="fs-hero__name" transition:name={`name-${player.slug}`}>
        {player.fullName}
        {isApprox && <span class="fs-approximate" title="Stats may have moved since this profile was last verified">approx.</span>}
      </h1>

      <div class="fs-hero__meta">
        <div class="fs-hero__meta-cell">
          <span class="fs-hero__meta-label">Born</span>
          <span class="fs-hero__meta-value">{bornDisplay}</span>
        </div>
        <div class="fs-hero__meta-cell">
          <span class="fs-hero__meta-label">From</span>
          <span class="fs-hero__meta-value">{player.birthplace}</span>
        </div>
        <div class="fs-hero__meta-cell">
          <span class="fs-hero__meta-label">Height</span>
          <span class="fs-hero__meta-value">{formatHeight(player.heightCm)}</span>
        </div>
        <div class="fs-hero__meta-cell">
          <span class="fs-hero__meta-label">Plays</span>
          <span class="fs-hero__meta-value">{handLabel}</span>
        </div>
        <div class="fs-hero__meta-cell">
          <span class="fs-hero__meta-label">Backhand</span>
          <span class="fs-hero__meta-value">{bhLabel}</span>
        </div>
        <div class="fs-hero__meta-cell">
          <span class="fs-hero__meta-label">Status</span>
          <span class="fs-hero__meta-value">{ageOrRetired}</span>
        </div>
      </div>
      </div>
    </div>
  </header>

  <article class="fs-container">
    <CmpCourtLine tone="rg" />
    <p class="fs-bio">{player.bio}</p>

    {aiCard && <CmpAiInsightCard card={aiCard} />}

    <section class="fs-section">
      <div class="fs-section__title">
        <h2>Career</h2>
        <span class="fs-eyebrow">{player.status === 'active' ? 'In progress' : 'Final ledger'}</span>
      </div>
      {arcData.length > 1 && (
        <div class="fs-arc-preview">
          <div class="fs-arc-preview__head">
            <span class="fs-eyebrow">Trajectory</span>
            <span class="fs-arc-preview__hint">
              {arcInverted ? 'ATP/WTA ranking · annual best' : 'Elo proxy · annual peaks'}
            </span>
          </div>
          <CmpRankingSparkline
            data={arcData}
            width={700}
            height={68}
            showAxis
            inverted={arcInverted}
          />
        </div>
      )}
      <div class="fs-stats">
        <CmpStatTile label="Grand Slams" value={player.career.grandSlams} transitionName={`slams-${player.slug}`} />
        <CmpStatTile label="Career-high" value={`#${player.career.careerHighRanking}`} small />
        <CmpStatTile label="Weeks at #1" value={player.career.weeksAtNumberOne} />
        <CmpStatTile label="Year-end #1" value={player.career.yearEndNumberOne} />
        <CmpStatTile label="Turned pro" value={player.career.turnedPro} small />
        <CmpStatTile
          label={player.status === 'active' ? 'Status' : 'Retired'}
          value={player.status === 'active' ? 'Active' : player.career.retiredYear}
          small
        />
      </div>
    </section>

    <CmpEloCareerArc slug={player.slug} />

    <CmpTrophyCase player={player} />

    {player.ledger && <CmpCareerLedger ledger={player.ledger} status={player.status} liveStats={liveStats} />}

    {clutch && <CmpClutch clutch={clutch} />}

    {styleNeighbours.length > 0 && (
      <section class="fs-section">
        <div class="fs-section__title">
          <h2>Style neighbours</h2>
          <span class="fs-eyebrow">By feature vector</span>
        </div>
        <CmpStyleNeighbours neighbours={styleNeighbours} />
      </section>
    )}

    {serveZones && <CmpServeRose zones={serveZones} />}

    {shotMap && <CmpShotMap map={shotMap} />}

    {player.equipment && (
      <>
        <CmpEquipmentBag equipment={player.equipment} />
        {player.accessories && (
          <div class="fs-container" style="margin-top: -1rem;">
            <CmpAccessories accessories={player.accessories} />
          </div>
        )}
      </>
    )}

    {player.projection && player.status === 'active' && (
      <CmpProjection projection={player.projection} currentSlams={player.career.grandSlams} />
    )}

    {player.quotes && player.quotes.length > 0 && <CmpQuotes quotes={player.quotes} />}

    <section class="fs-section">
      <div class="fs-section__title">
        <h2>Shot Palette</h2>
        <span class="fs-eyebrow">Typical-match values</span>
      </div>
      <CmpShotPalette palette={player.shotPalette} />
    </section>

    <section class="fs-section">
      <div class="fs-section__title">
        <h2>Style &amp; Surfaces</h2>
      </div>
      <div class="fs-style-grid">
        <div>
          <span class="fs-eyebrow fs-eyebrow--block">Style of play</span>
          <ul class="fs-tag-list">
            {player.styleOfPlay.map((s) => <li class="fs-tag fs-tag--solid">{s}</li>)}
          </ul>
        </div>
        <div>
          <span class="fs-eyebrow fs-eyebrow--block">Surface strengths</span>
          <ul class="fs-tag-list">
            {player.surfaceStrengths.map((s) => (
              <li class={`fs-tag ${
                s === 'clay'  ? 'fs-tag--clay'  :
                s === 'grass' ? 'fs-tag--grass' :
                s === 'hard'  ? 'fs-tag--hard'  : ''}`}>{s}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {player.signatureMatch && (
      <section class="fs-section">
        <div class="fs-signature">
          <div class="fs-signature__label">Signature match</div>
          {player.signatureMatch}
        </div>
      </section>
    )}

    {headToHeads.length > 0 && (
      <section class="fs-section fs-h2h-section">
        <div class="fs-section__title">
          <h2>Head to Head</h2>
          <span class="fs-eyebrow">Top {headToHeads.length} {headToHeads.length === 1 ? 'rivalry' : 'rivalries'}</span>
        </div>
        {headToHeads.map(({ rival, h2h }, i) => (
          <>
            {i > 0 && <CmpCourtLine tone="neutral" animate={false} />}
            <CmpHeadToHead playerA={player} playerB={rival} h2h={h2h} />
          </>
        ))}
      </section>
    )}

    {headToHeads.length === 0 && rivalEntries.length > 0 && (
      <section class="fs-section">
        <div class="fs-section__title">
          <h2>Rivalries</h2>
        </div>
        <ul class="fs-rivals">
          {rivalEntries.map((r) => (
            r.rival
              ? <li><a href={`/players/${r.rival.slug}`}>{r.rival.fullName}</a></li>
              : <li><span class="fs-rivals__missing">{r.slug.replace(/-/g, ' ')}</span></li>
          ))}
        </ul>
      </section>
    )}

    <a href="/" class="fs-back">← Back to roster</a>
  </article>
</LayBase>
