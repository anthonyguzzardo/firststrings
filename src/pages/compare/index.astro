---
import LayBase from '../../layouts/layBase.astro';
import { getPlayerBySlug, getPlayerImagePath } from '../../lib/libPlayers';
import { getHeadToHead, type HeadToHead } from '../../lib/libDb';
import '../../styles/styPlayerProfile.css';

// Hand-picked matchups that anchor the compare landing page. Each pair must
// resolve to two curated players — `getPlayerBySlug` returns null otherwise
// and the row drops out cleanly.
const FEATURED: Array<[string, string]> = [
  ['roger-federer',  'rafael-nadal'],
  ['roger-federer',  'novak-djokovic'],
  ['rafael-nadal',   'novak-djokovic'],
  ['jannik-sinner',  'carlos-alcaraz'],
  ['iga-swiatek',    'aryna-sabalenka'],
  ['serena-williams','venus-williams'],
];

interface Featured {
  a: ReturnType<typeof getPlayerBySlug>;
  b: ReturnType<typeof getPlayerBySlug>;
  h2h: HeadToHead | null;
}

const pairs: Featured[] = await Promise.all(
  FEATURED.map(async ([aSlug, bSlug]) => {
    const a = getPlayerBySlug(aSlug);
    const b = getPlayerBySlug(bSlug);
    if (!a || !b) return { a, b, h2h: null } as Featured;
    let h2h: HeadToHead | null = null;
    try {
      h2h = await getHeadToHead(aSlug, bSlug);
    } catch (e) {
      const code = (e as { code?: string } | null)?.code;
      if (code !== 'ECONNREFUSED') console.error('[compare-index]', e);
    }
    return { a, b, h2h };
  }),
);
const renderable = pairs.filter((p): p is { a: NonNullable<Featured['a']>; b: NonNullable<Featured['b']>; h2h: HeadToHead | null } => Boolean(p.a && p.b));
---
<LayBase title="Compare" description="Career head-to-head: tour-level singles, surface splits, and last meetings.">
  <header class="fs-roster-hero">
    <div class="fs-container">
      <div class="fs-eyebrow">First Strings</div>
      <h1>Compare them.</h1>
      <p class="fs-roster-hero__tagline">
        Two-portrait, one-number records. Surface splits. Last meeting. Pick a featured rivalry below, or open any
        player profile and tap a head-to-head score to deep-dive.
      </p>
    </div>
  </header>

  <section class="fs-container">
    <div class="fs-section">
      <div class="fs-section__title">
        <h2>Featured matchups</h2>
        <span class="fs-eyebrow">{renderable.length} {renderable.length === 1 ? 'pair' : 'pairs'}</span>
      </div>

      <ul class="fs-compare-grid">
        {renderable.map(({ a, b, h2h }) => (
          <li>
            <a class="fs-compare-card" href={`/compare/${a.slug}-vs-${b.slug}`}>
              <div class="fs-compare-card__photos">
                <img src={getPlayerImagePath(a)} alt="" class="fs-compare-card__photo" />
                <img src={getPlayerImagePath(b)} alt="" class="fs-compare-card__photo" />
              </div>
              <div class="fs-compare-card__names">
                <span>{a.fullName}</span>
                <span class="fs-compare-card__vs">vs.</span>
                <span>{b.fullName}</span>
              </div>
              {h2h ? (
                <div class="fs-compare-card__score">
                  <span>{h2h.aWins}</span>
                  <span class="fs-compare-card__sep">—</span>
                  <span>{h2h.bWins}</span>
                </div>
              ) : (
                <div class="fs-compare-card__score fs-compare-card__score--empty">no record</div>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</LayBase>

<style>
  .fs-compare-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }
  .fs-compare-card {
    background: var(--bg);
    padding: 1.5rem 1.5rem 1.75rem;
    display: grid;
    gap: 0.75rem;
    color: var(--ink);
  }
  .fs-compare-card:hover { background: var(--bg-elevated); }
  @media (prefers-reduced-motion: no-preference) {
    .fs-compare-card { transition: background var(--t-base) var(--ease); }
  }
  .fs-compare-card__photos {
    display: flex;
    gap: -8px;
    margin-bottom: 0.25rem;
  }
  .fs-compare-card__photo {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    object-fit: cover;
    background: var(--bg-elevated);
    border: 2px solid var(--bg);
    margin-right: -10px;
  }
  .fs-compare-card__names {
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.2;
    text-wrap: balance;
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.4rem;
  }
  .fs-compare-card__vs {
    font-style: italic;
    color: var(--ink-muted);
  }
  .fs-compare-card__score {
    font-family: var(--serif);
    font-size: 1.8rem;
    line-height: 1;
    color: var(--ink);
    display: flex;
    gap: 0.4rem;
    align-items: baseline;
    font-feature-settings: 'tnum' 1, 'lnum' 1;
    font-variant-numeric: tabular-nums lining-nums;
  }
  .fs-compare-card__sep { color: var(--ink-soft); font-size: 0.7em; }
  .fs-compare-card__score--empty {
    color: var(--ink-soft);
    font-size: 0.9rem;
    font-style: italic;
  }
</style>
