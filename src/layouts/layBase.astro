---
import '../styles/styBase.css';
import CmpUtilityBar from '../components/cmpUtilityBar.astro';
import CmpQuickSearch from '../components/cmpQuickSearch.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'A reverence for the game — profiles, comparisons, and lore from the legends of tennis.', ogImage } = Astro.props;
const fullTitle = `${title} · First Strings`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    {ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body>
    <CmpUtilityBar />
    <nav class="fs-nav">
      <div class="fs-container fs-nav__inner">
        <a href="/" class="fs-brand">First<span class="fs-brand__mark">·</span>Strings</a>
        <div class="fs-nav__links">
          <a href="/">Roster</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <CmpQuickSearch />

    <footer class="fs-foot">
      <div class="fs-container fs-foot__inner">
        <span>First Strings — a tennis fandom project.</span>
        <span>Depth over speed.</span>
      </div>
    </footer>
  </body>
</html>
